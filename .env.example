# -------------------------------------------------------
# EcoVerse — Environment Variables
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to version control.
# -------------------------------------------------------

# Firebase (client-side — NEXT_PUBLIC_ prefix required)
NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# MongoDB (server-side only — no NEXT_PUBLIC_ prefix)
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/carbontracker

# JWT (server-side only)
JWT_SECRET=replace_with_a_long_random_secret

# Gemini AI Configuration
GEMINI_API_KEY=your_gemini_api_key_here

# MongoDB Local Container Credentials
MONGO_INITDB_ROOT_USERNAME=ecoverse_dev
MONGO_INITDB_ROOT_PASSWORD=ecoverse_dev_password